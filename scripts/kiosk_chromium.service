[Unit]
Description=Kiosk Chromium for Kiosk Checkpoint
After=graphical.target network-online.target
Wants=graphical.target

[Service]
User=pi
Environment=DISPLAY=:0
Type=simple
ExecStart=/usr/bin/chromium-browser --noerrdialogs --kiosk --incognito --disable-translate --disable-infobars http://localhost:8080
Restart=always
RestartSec=5

[Install]
WantedBy=graphical.target
